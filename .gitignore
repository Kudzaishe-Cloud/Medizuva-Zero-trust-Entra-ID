# They are regenerated on every CI/CD run using real credentials.
data/personas/*.csv
data/osint_results/*.json
data/osint_results/*.log
data/risky_users.json
data/threat_audit.json
data/ca_audit.json
data/ca_policy_status.json
data/nist_compliance_report.json
data/pim_audit.json
data/pim_validation_issues.csv
