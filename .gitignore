# ── Secrets / local config ────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets.json

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Node / npm (if any front-end tooling) ─────────────────────
node_modules/

# ── OS artefacts ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Generated pipeline output (regenerated on every CI/CD run) ───────
data/personas/*.csv
data/osint_results/*.json
data/osint_results/*.log
data/risky_users.json
data/threat_audit.json
data/ca_audit.json
data/ca_policy_status.json
data/pim_audit.json
data/pim_validation_issues.csv
data/pim_validation_report.txt

# These two are committed by the pipeline so they persist between runs
# and are available to the dashboard builder in every workflow.
!data/osint_results/osint_combined_results.json
!data/nist_compliance_report.json

# ── PowerShell temp ───────────────────────────────────────────
*.ps1xml
