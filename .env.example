# Copy this file to .env for local development.
# NEVER commit .env — it is in .gitignore.
#
# In GitHub Actions these are set as repository secrets:
#   Settings → Secrets and variables → Actions → New repository secret

# ── Azure Entra ID (app registration) ────────────────────────
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_CLIENT_ID=your-client-id-here
ENTRA_CLIENT_SECRET=your-client-secret-here

# ── OSINT API keys (optional — scripts fall back to CSV mode) ─
HIBP_API_KEY=your-hibp-key-here
DEHASHED_EMAIL=you@example.com
DEHASHED_API_KEY=your-dehashed-key-here
LEAKCHECK_API_KEY=your-leakcheck-key-here
INTELX_API_KEY=your-intelx-key-here
